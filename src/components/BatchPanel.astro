---
import Close from "@/assets/svg/close.svg"
import { useTranslations } from "@/i18n/ui"

const t = useTranslations(Astro.currentLocale)
---

<section id="batch-panel" class="batch-panel" hidden>
  <div class="batch-backdrop" id="batch-backdrop"></div>
  <div class="batch-card" role="dialog" aria-modal="true" aria-label={t.batch.title}>
    <header class="batch-head">
      <h2>{t.batch.title}</h2>
      <button id="batch-close" class="btn-icon" type="button" aria-label={t.batch.close}>
        <Close />
      </button>
    </header>

    <div class="batch-columns">
      <div class="batch-browser">
        <nav id="batch-crumbs" class="batch-crumbs" aria-label={t.batch.pathAria}></nav>
        <div class="batch-toolbar">
          <input id="batch-filter" type="search" placeholder={t.batch.filter} />
          <button id="batch-add-folder" class="btn-soft" type="button" title={t.batch.addFolderTitle}>
            ＋ {t.batch.addFolder}
          </button>
        </div>
        <ul id="batch-listing" class="batch-listing"></ul>
      </div>

      <div class="batch-side">
        <h3>{t.batch.queueTitle}</h3>
        <ul id="batch-queue" class="batch-queue"></ul>

        <div class="batch-field">
          <span>{t.batch.subtitleLangs}</span>
          <div id="batch-langs" class="batch-chips"></div>
          <small class="batch-hint">{t.batch.subtitleLangsHint}</small>
        </div>

        <div class="batch-options">
          <label><span>{t.batch.mode}</span>
            <select id="batch-mode">
              <option value="sidecar" selected>{t.batch.modeSidecar}</option>
              <option value="both">{t.batch.modeBoth}</option>
              <option value="mux">{t.batch.modeMux}</option>
            </select>
          </label>
          <label><span>{t.batch.model}</span>
            <select id="batch-model">
              <option value="large-v3-turbo">large-v3-turbo</option>
              <option value="large-v3">large-v3</option>
              <option value="medium">medium</option>
              <option value="small">small</option>
              <option value="base">base</option>
              <option value="tiny">tiny</option>
            </select>
          </label>
          <label><span>{t.batch.language}</span>
            <select id="batch-lang"></select>
          </label>
          <label><span>{t.batch.outputDir}</span>
            <input id="batch-output-dir" type="text" />
          </label>
          <label class="batch-check">
            <input id="batch-recursive" type="checkbox" checked />
            <span>{t.batch.recursive}</span>
          </label>
          <label class="batch-check">
            <input id="batch-vad" type="checkbox" />
            <span>{t.batch.vad}</span>
          </label>
          <label class="batch-span2"><span>{t.batch.vadThreshold}</span>
            <span class="batch-vad-row">
              <input id="batch-vad-threshold" type="range" min="0.1" max="0.9" step="0.05" value="0.5" />
              <output id="batch-vad-value">0.50</output>
            </span>
          </label>
        </div>

        <div class="batch-actions">
          <button id="batch-start" class="btn-primary" type="button">{t.batch.start}</button>
          <button id="batch-cancel" class="btn-soft" type="button" hidden>{t.batch.cancel}</button>
        </div>
      </div>
    </div>

    <div id="batch-files" class="batch-files"></div>
    <div class="batch-statusbar">
      <p id="batch-status" class="batch-status" role="status" aria-live="polite"></p>
      <p id="batch-times" class="batch-times"></p>
    </div>
  </div>
</section>

<style is:global>
  .batch-panel { position: fixed; inset: 0; z-index: 60; display: grid; place-items: center; padding: 2rem 1rem; color-scheme: dark; }
  .batch-backdrop { position: absolute; inset: 0; background: rgb(0 0 0 / 0.6); backdrop-filter: blur(4px); }
  .batch-card {
    position: relative; width: min(980px, 100%); max-height: 92vh; overflow: auto;
    background: #101014; border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: 16px; padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 1rem;
  }
  .batch-head { display: flex; align-items: center; justify-content: space-between; }
  .batch-head h2 { font-size: 1.1rem; }
  .batch-columns { display: grid; grid-template-columns: 1.1fr 1fr; gap: 1rem; }
  @media (max-width: 720px) { .batch-columns { grid-template-columns: 1fr; } }

  /* ── Browser ── */
  .batch-browser { display: flex; flex-direction: column; gap: 0.5rem; min-width: 0; }
  .batch-crumbs { display: flex; flex-wrap: wrap; gap: 0.15rem; align-items: center; font-size: 0.78rem; min-height: 1.4em; }
  .batch-crumbs button {
    background: none; border: 0; color: #8fa3c8; cursor: pointer; padding: 0.1rem 0.25rem;
    border-radius: 4px; font: inherit; max-width: 16ch; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .batch-crumbs button:hover { background: rgb(255 255 255 / 0.08); color: #dfe6f3; }
  .batch-crumbs .crumb-sep { opacity: 0.4; }
  .batch-toolbar { display: flex; gap: 0.5rem; }
  .batch-toolbar input[type="search"] {
    flex: 1; min-width: 0; background: #0e1118; border: 1px solid #1c2234; border-radius: 8px;
    padding: 0.35rem 0.6rem; color: #c3cbdd; font: inherit; font-size: 0.82rem;
  }
  .batch-listing {
    list-style: none; margin: 0; padding: 0.25rem; height: 280px; overflow: auto;
    border: 1px solid rgb(255 255 255 / 0.1); border-radius: 10px; font-size: 0.85rem;
  }
  .batch-listing li {
    padding: 0.22rem 0.35rem 0.22rem 0.5rem; border-radius: 6px; display: flex; gap: 0.45rem; align-items: center;
  }
  .batch-listing li.is-dir { cursor: pointer; }
  .batch-listing li:hover { background: rgb(255 255 255 / 0.07); }
  .batch-listing li.is-selected { background: rgb(99 102 241 / 0.25); }
  .batch-listing .row-label { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .batch-listing .size { margin-left: auto; opacity: 0.55; font-size: 0.75rem; flex: none; }
  .batch-listing .row-add {
    flex: none; width: 1.6rem; height: 1.6rem; border-radius: 6px; border: 1px solid #2e3a52;
    background: #141926; color: #b8f060; cursor: pointer; font-size: 0.95rem; line-height: 1;
  }
  .batch-listing .row-add:hover { background: #1c2436; }

  /* ── Queue ── */
  .batch-side { display: flex; flex-direction: column; gap: 0.6rem; min-width: 0; }
  .batch-side h3 { font-size: 0.9rem; opacity: 0.85; }
  .batch-queue {
    list-style: none; margin: 0; padding: 0.25rem; min-height: 56px; max-height: 140px; overflow: auto;
    border: 1px dashed rgb(255 255 255 / 0.15); border-radius: 10px; font-size: 0.8rem;
  }
  .batch-queue li {
    display: flex; align-items: center; gap: 0.35rem; padding: 0.18rem 0.3rem; border-radius: 6px;
  }
  .batch-queue li[draggable="true"] { cursor: grab; }
  .batch-queue li.drag-over { outline: 2px dashed #6366f1; outline-offset: -2px; }
  .batch-queue li.batch-empty { opacity: 0.5; }
  .batch-queue .q-handle { opacity: 0.4; flex: none; }
  .batch-queue .q-label { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; min-width: 0; }
  .batch-queue button {
    flex: none; background: none; border: 0; color: #8fa3c8; cursor: pointer; padding: 0 0.2rem;
    font-size: 0.85rem; border-radius: 4px;
  }
  .batch-queue button:hover { color: #fff; background: rgb(255 255 255 / 0.1); }
  .batch-queue button:disabled { opacity: 0.25; cursor: default; }

  /* ── Language chips (single unified subtitle selector) ── */
  .batch-field { display: flex; flex-direction: column; gap: 0.3rem; font-size: 0.8rem; }
  .batch-field > span { opacity: 0.75; }
  .batch-hint { opacity: 0.5; font-size: 0.72rem; }
  .batch-chips { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .batch-chips button {
    border: 1px solid #1c2234; background: #0e1118; color: #c3cbdd; border-radius: 999px;
    padding: 0.18rem 0.65rem; font: inherit; font-size: 0.76rem; cursor: pointer;
  }
  .batch-chips button:hover { border-color: #2e3a52; }
  .batch-chips button.is-on { background: rgb(184 240 96 / 0.16); border-color: #b8f060; color: #d9f7ac; }
  .batch-chips button.is-fixed { background: rgb(99 102 241 / 0.18); border-color: #6366f1; color: #c7cbff; cursor: default; }

  /* ── Options ── */
  .batch-options { display: grid; grid-template-columns: 1fr 1fr; gap: 0.55rem 0.8rem; font-size: 0.8rem; }
  .batch-options label { display: flex; flex-direction: column; gap: 0.25rem; min-width: 0; }
  .batch-options label > span:first-child { opacity: 0.75; }
  .batch-options select, .batch-options input[type="text"] {
    background-color: #0e1118; border: 1px solid #1c2234; color: #c3cbdd;
    border-radius: 8px; padding: 0.35rem 0.5rem; font: inherit; font-size: 0.82rem;
  }
  .batch-options select option, .batch-listing select option { background: #0e1118; color: #c3cbdd; }
  .batch-span2 { grid-column: span 2; }
  .batch-check { flex-direction: row !important; align-items: center; gap: 0.45rem !important; }
  .batch-vad-row { display: flex; align-items: center; gap: 0.6rem; }
  .batch-vad-row input { flex: 1; }
  .batch-actions { display: flex; gap: 0.6rem; margin-top: auto; }

  /* ── Progress rows + status ── */
  .batch-files { display: flex; flex-direction: column; gap: 0.4rem; }
  .batch-file-row {
    display: grid; grid-template-columns: minmax(0, 1fr) 110px minmax(0, 2fr) 90px;
    gap: 0.7rem; align-items: center; font-size: 0.8rem;
    padding: 0.35rem 0.6rem; border: 1px solid rgb(255 255 255 / 0.08); border-radius: 8px;
  }
  .batch-file-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .batch-file-state { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; opacity: 0.85; }
  .batch-file-state[data-state="done"] { color: #4ade80; }
  .batch-file-state[data-state="error"] { color: #f87171; }
  .batch-file-state[data-state="skipped"], .batch-file-state[data-state="cancelled"] { opacity: 0.55; }
  .batch-file-bar { height: 6px; border-radius: 999px; background: rgb(255 255 255 / 0.08); overflow: hidden; }
  .batch-file-bar > i { display: block; height: 100%; width: 0%; background: linear-gradient(90deg, #6366f1, #22d3ee); transition: width 0.4s ease; }
  .batch-file-detail { opacity: 0.6; text-align: right; font-variant-numeric: tabular-nums; }
  .batch-statusbar { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .batch-status { font-size: 0.85rem; opacity: 0.85; min-height: 1.2em; }
  .batch-times { font-size: 0.78rem; opacity: 0.6; font-variant-numeric: tabular-nums; }
</style>
