---
import DropzoneIcon from "@/assets/svg/dropzone.svg"
import HeroUnderline from "@/assets/svg/hero-underline.svg"
import BatchPanel from "@/components/BatchPanel.astro"
import { useTranslations } from "@/i18n/ui"

const t = useTranslations(Astro.currentLocale)
---

<section id="stage-upload" class="stage-upload">
  <div class="stage-aurora" aria-hidden="true">
    <svg
      class="stage-bg-icon stage-bg-icon--video"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
      <path d="M15 10l4.553 -2.276a1 1 0 0 1 1.447 .894v6.764a1 1 0 0 1 -1.447 .894l-4.553 -2.276v-4"></path>
      <path d="M3 8a2 2 0 0 1 2 -2h8a2 2 0 0 1 2 2v8a2 2 0 0 1 -2 2h-8a2 2 0 0 1 -2 -2l0 -8"></path>
    </svg>
    <svg
      class="stage-bg-icon stage-bg-icon--subtitles"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
      <path d="M11.5 19h-5.5a3 3 0 0 1 -3 -3v-8a3 3 0 0 1 3 -3h12a3 3 0 0 1 3 3v4"></path>
      <path d="M7 15h5"></path>
      <path d="M17 12h-3"></path>
      <path d="M11 12h-1"></path>
      <path d="M19 22.5a4.75 4.75 0 0 1 3.5 -3.5a4.75 4.75 0 0 1 -3.5 -3.5a4.75 4.75 0 0 1 -3.5 3.5a4.75 4.75 0 0 1 3.5 3.5"></path>
    </svg>
  </div>

  <div class="hero">
    <span class="hero-badge">
      <span class="hero-badge-dot"></span>
      {t.hero.badge}
    </span>
    <h1 class="hero-title">
      <span class="hero-word">{t.hero.titleSubtitles}</span>
      <span class="hero-word">{t.hero.titleFor}</span>
      <span class="hero-mark">
        <HeroUnderline class="hero-underline" />
        <span class="hero-mark-text" set:html={t.hero.titleAny} />
      </span>
    </h1>
    <p class="hero-sub">{t.hero.sub}</p>
  </div>

  <div class="mode-grid">
    <div class="mode-card">
      <div class="mode-card-head">
        <h2>{t.modes.singleTitle}</h2>
        <p>{t.modes.singleDesc}</p>
      </div>
      <div
        id="dropzone"
        class="dropzone"
        role="button"
        tabindex="0"
        aria-label={t.hero.dropAria}
        data-default-label={t.hero.dropLabel}
        data-default-hint={t.hero.dropHint}
        data-unsupported-label={t.hero.dropUnsupportedLabel}
        data-unsupported-hint={t.hero.dropUnsupportedHint}
      >
        <input id="video-input" type="file" accept="video/*,audio/*" hidden />
        <span class="dz-spotlight" aria-hidden="true"></span>
        <div class="dz-body">
          <span class="dz-icon-wrap">
            <span class="dz-pulse" aria-hidden="true"></span>
            <span class="dz-pulse dz-pulse--2" aria-hidden="true"></span>
            <DropzoneIcon class="dz-icon" />
          </span>
          <strong id="dropzone-label" class="dz-label">{t.hero.dropLabel}</strong>
          <span id="dropzone-hint" class="dz-hint" aria-live="polite">
            {t.hero.dropHint}
          </span>
        </div>
      </div>
    </div>

    <div class="mode-card">
      <div class="mode-card-head">
        <h2>⚡ {t.modes.batchTitle}</h2>
        <p>{t.modes.batchDesc}</p>
      </div>
      <div class="mode-card-body">
        <div id="engine-on" hidden>
          <span id="engine-badge" class="engine-badge"></span>
          <button id="batch-open" class="btn-primary" type="button">
            {t.batch.open}
          </button>
        </div>
        <div id="engine-off">
          <span class="engine-badge engine-badge--off">{t.modes.engineMissing}</span>
          <p class="engine-help">{t.modes.engineNeeded}</p>
          <code class="engine-cmd">python cli/subvid_server.py</code>
          <button id="engine-retry" class="btn-soft" type="button">
            {t.modes.engineRetry}
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<BatchPanel />

<style is:global>
  .mode-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.25rem;
    width: min(980px, 100%);
    margin-inline: auto;
    align-items: stretch;
  }
  .mode-card {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    background: rgb(255 255 255 / 0.02);
    border: 1px solid rgb(255 255 255 / 0.08);
    border-radius: 18px;
    padding: 1.1rem 1.2rem 1.2rem;
  }
  .mode-card-head h2 { font-size: 1.02rem; margin-bottom: 0.3rem; }
  .mode-card-head p { font-size: 0.82rem; opacity: 0.65; line-height: 1.45; }
  .mode-card .dropzone { flex: 1; width: 100%; }
  .mode-card-body {
    flex: 1;
    display: grid;
    place-items: center;
    border: 1.5px dashed rgb(255 255 255 / 0.12);
    border-radius: 14px;
    padding: 1.2rem;
    min-height: 180px;
  }
  #engine-on, #engine-off {
    display: flex; flex-direction: column; align-items: center; gap: 0.8rem; text-align: center;
  }
  #engine-on[hidden], #engine-off[hidden] { display: none; }
  .engine-help { font-size: 0.8rem; opacity: 0.65; }
  .engine-cmd {
    background: #0e1118; border: 1px solid #1c2234; border-radius: 8px;
    padding: 0.4rem 0.8rem; font-size: 0.8rem; color: #b8f060; user-select: all;
  }
  .engine-badge--off { border-color: rgb(248 113 113 / 0.4); color: #f87171; }
</style>

<script>
  const dropzone = document.getElementById("dropzone")
  if (dropzone && !matchMedia("(prefers-reduced-motion: reduce)").matches) {
    let rafId = 0
    let pendingX = 0
    let pendingY = 0
    dropzone.addEventListener("pointermove", (event) => {
      pendingX = event.clientX
      pendingY = event.clientY
      if (rafId) return
      rafId = requestAnimationFrame(() => {
        rafId = 0
        const rect = dropzone.getBoundingClientRect()
        dropzone.style.setProperty("--mx", `${pendingX - rect.left}px`)
        dropzone.style.setProperty("--my", `${pendingY - rect.top}px`)
      })
    })
  }
</script>
