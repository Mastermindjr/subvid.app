---
import Check from "@/assets/svg/check.svg"
import Ring from "@/assets/svg/ring.svg"
import { languages, defaultLang, toLang, useTranslations } from "@/i18n/ui"

const t = useTranslations(Astro.currentLocale)
const current = toLang(Astro.currentLocale)
const localePath = (code: string) => (code === defaultLang ? "/" : `/${code}/`)
---

<div id="status-dock" class="status-dock">
  <span id="downloads-label" class="status-label" role="status" aria-live="polite"></span>
  <button
    id="downloads-toggle"
    class="status-btn"
    aria-label={t.status.modelsAria}
    type="button"
  >
    <Ring class="ring" />
    <span id="downloads-pct" class="ring-pct">0%</span>
    <Check class="ring-check" />
  </button>
  <nav class="top-lang" aria-label={t.footer.language}>
    {
      Object.entries(languages).map(([code, name]) => (
        <a
          class="top-lang-link"
          href={localePath(code)}
          hreflang={code}
          data-locale={code}
          title={name}
          aria-current={code === current ? "true" : undefined}
        >
          {code.toUpperCase()}
        </a>
      ))
    }
  </nav>
</div>
