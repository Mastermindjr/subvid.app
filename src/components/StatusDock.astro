---
import Check from "@/assets/svg/check.svg"
import Ring from "@/assets/svg/ring.svg"
import { languages, defaultLang, toLang, useTranslations } from "@/i18n/ui"

const t = useTranslations(Astro.currentLocale)
const current = toLang(Astro.currentLocale)
const localePath = (code: string) => (code === defaultLang ? "/" : `/${code}/`)
---

<div id="status-dock" class="status-dock">
  <span id="downloads-label" class="status-label" role="status" aria-live="polite"></span>
  <button
    id="downloads-toggle"
    class="status-btn"
    aria-label={t.status.modelsAria}
    type="button"
  >
    <Ring class="ring" />
    <span id="downloads-pct" class="ring-pct">0%</span>
    <Check class="ring-check" />
  </button>
  <div class="app-mode" role="group" aria-label={t.appMode.label}>
    <button id="app-mode-local" class="app-mode-btn" type="button" aria-pressed="true">
      💻 {t.appMode.local}
    </button>
    <button
      id="app-mode-server"
      class="app-mode-btn"
      type="button"
      aria-pressed="false"
      title={t.appMode.serverTitle}
    >
      🔐 {t.appMode.server}
    </button>
  </div>
  <nav class="top-lang" aria-label={t.footer.language}>
    {
      Object.entries(languages).map(([code, name]) => (
        <a
          class="top-lang-link"
          href={localePath(code)}
          hreflang={code}
          data-locale={code}
          title={name}
          aria-current={code === current ? "true" : undefined}
        >
          {code.toUpperCase()}
        </a>
      ))
    }
  </nav>
</div>

<style is:global>
  .app-mode {
    display: flex; gap: 0.15rem; border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: 999px; padding: 0.15rem;
  }
  .app-mode-btn {
    border: 0; background: none; color: #8fa3c8; font: inherit; font-size: 0.72rem;
    padding: 0.22rem 0.7rem; border-radius: 999px; cursor: pointer; white-space: nowrap;
  }
  .app-mode-btn:hover { color: #dfe6f3; background: rgb(255 255 255 / 0.07); }
  .app-mode-btn[aria-pressed="true"] {
    background: rgb(184 240 96 / 0.16); color: #d9f7ac; cursor: default;
  }
</style>
